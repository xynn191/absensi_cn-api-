APP_NAME=Absensi CN API
APP_ENV=production
APP_PORT=8080
API_PREFIX=/api/v1
APP_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app,https://*.vercel.app

DB_ENABLED=false
DB_DSN=
DATABASE_URL=
MYSQL_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=absensi_cn
DB_USER=root
DB_PASSWORD=
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local

JWT_SECRET=replace-with-secure-secret
JWT_EXPIRES_IN_HOURS=24

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=absensi-cn

# Railway examples:
# DATABASE_URL=mysql://root:password@host.railway.internal:3306/railway
# APP_ALLOWED_ORIGINS=https://your-app.vercel.app,https://*.vercel.app
